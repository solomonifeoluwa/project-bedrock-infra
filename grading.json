{
  "project": "project-bedrock-infra",
  "student": "Solomon Olakulehin",
  "email": "ezebina360@gmail.com",
  "version": "1.0.0",
  "components": {
    "vpc": {
      "file": "vpc.tf",
      "resources": [
        "aws_vpc",
        "aws_internet_gateway",
        "aws_subnet",
        "aws_eip",
        "aws_nat_gateway",
        "aws_route_table",
        "aws_route_table_association"
      ]
    },
    "eks": {
      "file": "eks.tf",
      "resources": [
        "aws_eks_cluster",
        "aws_eks_node_group"
      ]
    },
    "rds": {
      "file": "rds.tf",
      "resources": [
        "aws_db_subnet_group",
        "aws_security_group",
        "aws_db_instance"
      ]
    },
    "dynamodb": {
      "file": "dynamodb.tf",
      "resources": [
        "aws_dynamodb_table"
      ]
    },
    "s3": {
      "file": "s3.tf",
      "resources": [
        "aws_s3_bucket",
        "aws_s3_bucket_versioning",
        "aws_s3_bucket_server_side_encryption_configuration",
        "aws_s3_bucket_public_access_block"
      ]
    },
    "lambda": {
      "file": "lambda.tf",
      "resources": [
        "aws_security_group",
        "aws_lambda_function",
        "aws_cloudwatch_log_group"
      ]
    },
    "iam": {
      "file": "iam.tf",
      "resources": [
        "aws_iam_role",
        "aws_iam_role_policy_attachment",
        "aws_iam_policy"
      ]
    }
  },
  "backend": {
    "type": "s3",
    "bucket": "project-bedrock-tfstate",
    "dynamodb_table": "project-bedrock-tfstate-lock"
  }
}
